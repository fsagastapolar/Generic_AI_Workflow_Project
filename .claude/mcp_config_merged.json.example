{
  "mcpServers": {
    "linear": {
      "command": "node",
      "args": [
        "node_modules/@mseep/linear-mcp-server/dist/index.js"
      ],
      "env": {
        "LINEAR_API_KEY": "your_linear_api_key_here"
      }
    },
    "playwright": {
      "command": "node",
      "args": ["node_modules/@playwright/mcp/cli.js"]
    }
  }
}
