# Linear Integration
# Required when linear.enabled is true in project.config.json
# Generate your API key at: https://linear.app/settings/api
LINEAR_API_KEY=your_linear_api_key_here

# Team ID — found in Linear team settings or via the API
# You can find this by querying: curl -s -X POST https://api.linear.app/graphql \
#   -H "Authorization: $LINEAR_API_KEY" -H "Content-Type: application/json" \
#   -d '{"query":"{ teams { nodes { id name key } } }"}' | jq .
LINEAR_TEAM_ID=your_linear_team_id_here

# Project ID (optional) — defaults all ticket creation to this project
# Find via: curl -s -X POST https://api.linear.app/graphql \
#   -H "Authorization: $LINEAR_API_KEY" -H "Content-Type: application/json" \
#   -d '{"query":"{ projects { nodes { id name teams { nodes { key } } } } }"}' | jq .
LINEAR_PROJECT_ID=
