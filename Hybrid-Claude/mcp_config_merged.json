{
  "mcpServers": {
    "linear": {
      "command": "node",
      "args": [
        "node_modules/@mseep/linear-mcp-server/dist/index.js"
      ],
      "env": {
        "LINEAR_API_KEY": "Linear API KEY HERE"
      }
    },
    "playwright": {
      "command": "node",
      "args": ["node_modules/@playwright/mcp/cli.js"]
    }
  }
}
